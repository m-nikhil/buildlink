rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles collection rules
    match /profiles/{profileId} {
      // Anyone authenticated can read profiles (for the feed)
      allow read: if request.auth != null;
      
      // Users can create their own profile
      // The user_id field must match their Firebase Auth UID (which equals Supabase user ID)
      allow create: if request.auth != null 
                    && request.resource.data.user_id == request.auth.uid;
      
      // Users can update their own profile (user_id field must match)
      allow update: if request.auth != null 
                    && resource.data.user_id == request.auth.uid;
      
      // Users can only delete their own profile
      allow delete: if request.auth != null 
                    && resource.data.user_id == request.auth.uid;
    }
    
    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
